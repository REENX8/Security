{
  "manifest_version": 3,
  "name": "Thai Phishing Detector",
  "short_name": "PhishDetector",
  "version": "1.2.0",
  "description": "Real-time detection of phishing URLs impersonating Thai government (.go.th) and education (.ac.th) websites.",
  "author": "Thai Phishing Detector contributors",
  "homepage_url": "https://github.com/reenx8/security",
  "minimum_chrome_version": "108",

  "permissions": [
    "webNavigation",
    "notifications",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Thai Phishing Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["warning.html", "warning.css", "warning.js", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "thai-phishing-detector@reenx8.github.io",
      "strict_min_version": "121.0"
    }
  }
}
