{
  "manifest_version": 3,
  "name": "Thai Phishing Detector",
  "version": "1.0.0",
  "description": "ตรวจจับเว็บไซต์ฟิชชิงที่ปลอมเป็นหน่วยงานราชการและสถาบันการศึกษาไทยแบบเรียลไทม์",
  "permissions": ["webNavigation", "notifications", "storage", "tabs", "activeTab"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Thai Phishing Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
