# ----------------------------------------------------------------------
# Thai Phishing URL Detection -- environment configuration
# Copy to .env and adjust values.  docker-compose reads this file.
# ----------------------------------------------------------------------

# --- Database -----------------------------------------------------------
# PostgreSQL (default, used by docker-compose):
DATABASE_URL=postgresql+asyncpg://phish:phish@db:5432/phishdb
# Zero-setup local demo without PostgreSQL (uncomment to use SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./phish.db

# --- Security -----------------------------------------------------------
# Shared secret the browser extension / dashboard send as the X-API-Key header.
# CHANGE THIS in any real deployment.
API_KEY=dev-local-key-change-me

# Comma-separated allowed CORS origins (the dashboard). Chrome extension
# origins (chrome-extension://...) are always allowed via a regex.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate limiting ------------------------------------------------------
RATE_LIMIT=100/minute

# --- Feature extraction (network lookups) -------------------------------
# WHOIS / TLS lookups enrich the verdict but add latency. They are always
# timeout-guarded and fall back to safe defaults.
ENABLE_WHOIS=true
ENABLE_TLS=true
NETWORK_TIMEOUT=2.5

# --- Scoring thresholds -------------------------------------------------
THRESHOLD_SUSPICIOUS=0.3
THRESHOLD_PHISHING=0.7

# --- Observability ------------------------------------------------------
# "text" (default) for human-readable access logs.
# "json" for one-line JSON per request (Loki / CloudWatch / Datadog).
LOG_FORMAT=text

# --- Public threat feed -------------------------------------------------
# /api/v1/feed.{json,csv,stix} -- expose recent phishing verdicts without
# requiring an API key. Set to false to keep all data private.
ENABLE_PUBLIC_FEED=true

# --- Campaign clustering ------------------------------------------------
# Group similar phishing URLs (same brand + tld + path shape) so the
# dashboard can show campaigns. Disable if you don't want clustering rows
# stored.
ENABLE_CAMPAIGN_TRACKING=true

# --- PostgreSQL container credentials (used by docker-compose) ----------
POSTGRES_USER=phish
POSTGRES_PASSWORD=phish
POSTGRES_DB=phishdb
