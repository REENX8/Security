{"nodes": [{"id": "security_readme_phishing_detection_system", "label": "Thai Phishing Detection System", "file_type": "concept", "source_file": "README.md", "source_location": "line 1", "source_url": "https://github.com/REENX8/Security", "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "Built specifically for Thai-targeting phishing (gov .go.th, edu .ac.th, state banks) because global systems lack Thai whitelists and training data. End-to-end stack chosen so ML pipeline and backend share the same phish_features package as single source of truth, preventing train/serve skew."}, {"id": "security_readme_phish_features_package", "label": "phish_features Shared Package", "file_type": "concept", "source_file": "README.md", "source_location": "line 157-165", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "Designed as a single shared package imported by both ML pipeline and backend to ensure identical feature computation at train-time and serve-time, eliminating train/serve skew."}, {"id": "security_readme_feature_schema_v140", "label": "Feature Schema v1.4.0 (37 features)", "file_type": "concept", "source_file": "README.md", "source_location": "line 79-83", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "37 features across lexical, domain, whitelist, TLS, IDN/homoglyph, path-impersonation, and new v1.4 lexical-rich groups. Four new v1.4 features (num_login_keywords, query_param_count, path_entropy, host_token_count) added because phishing kits stuff multiple keywords, redirect kits use many params, random paths have high entropy, and brand-stuffed domains have many hostname tokens."}, {"id": "security_readme_ml_ensemble", "label": "ML Ensemble (RandomForest + XGBoost)", "file_type": "concept", "source_file": "README.md", "source_location": "line 41-43", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "RF captures non-linear interactions well; XGB captures tail (rare patterns). Soft voting averages probabilities to reduce variance. Isotonic calibration ensures scores are true probabilities (not just rankings) so 0.7/0.3 thresholds have consistent meaning across datasets. Ensemble chosen over deep learning because inference must be <250ms p95 on 1 vCPU / 1GB RAM without GPU."}, {"id": "security_readme_rules_engine", "label": "Heuristic Rules Engine", "file_type": "concept", "source_file": "README.md", "source_location": "line 334-370", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "Three reasons for adding a rules layer on top of ML: (1) Transparency \u2014 each verdict exposes rule_ids that fired, (2) Emergency override without retraining, (3) Catching patterns rare in training data (e.g., @-trick) that ML under-weights."}, {"id": "security_readme_fastapi_backend", "label": "FastAPI Backend", "file_type": "concept", "source_file": "README.md", "source_location": "line 174-187", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null}, {"id": "security_readme_brand_watchlist_webhook", "label": "Brand Watchlist + Webhook", "file_type": "concept", "source_file": "README.md", "source_location": "line 374-403", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "Operators register brands and webhook URLs (Slack/LINE/SOAR); system sends instant alert when a phishing URL targeting that brand is detected, with retry and delivery log stored in webhook_delivery table."}, {"id": "security_readme_campaign_clustering", "label": "Campaign Clustering", "file_type": "concept", "source_file": "README.md", "source_location": "line 406-421", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "Fingerprint = brand|tld|path-shape groups URLs from the same phishing kit so operators can block entire campaigns instead of individual URLs."}, {"id": "security_readme_public_threat_feed", "label": "Public Threat Feed (JSON/CSV/STIX 2.1)", "file_type": "concept", "source_file": "README.md", "source_location": "line 425-436", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "No-auth public feed (STIX 2.1 for TAXII consumers, JSON/CSV for others) so the security community can ingest Thai phishing indicators without an API key. STIX 2.1 chosen because SIEM tools (Splunk, Elastic, Sentinel) parse it natively."}, {"id": "security_readme_browser_extension", "label": "Browser Extension (Manifest V3)", "file_type": "concept", "source_file": "README.md", "source_location": "line 463-477", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "Chrome/Edge/Brave/Opera/Firefox 121+ MV3 extension with full-page interstitial warning and per-session bypass. Extension sends only the URL (no cookies/credentials) to backend, preserving user privacy."}, {"id": "security_readme_citizen_report_portal", "label": "Citizen Report Portal", "file_type": "concept", "source_file": "README.md", "source_location": "line 490-498", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "No-login portal designed for general public including elderly users, enabling phishing reports that feed back into auto-retrain pipeline."}, {"id": "security_readme_url_unshortener", "label": "URL Unshortener", "file_type": "concept", "source_file": "README.md", "source_location": "line 87", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "Async HEAD request to expand short links (18 providers) before feature extraction, catching phishing hidden behind shortened URLs. Fail-open with 5s timeout."}, {"id": "security_readme_line_messaging_bot", "label": "LINE Messaging API Bot", "file_type": "concept", "source_file": "README.md", "source_location": "line 89", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "Allows general public to check URLs directly in LINE chat without installing anything, targeting Thai elderly users who use LINE extensively."}, {"id": "security_readme_content_based_fallback", "label": "Content-based Fallback", "file_type": "concept", "source_file": "README.md", "source_location": "line 91", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "For gray-zone URLs (score 0.3-0.7), fetches HTML to check for brand-in-title and password fields without headless browser. SSRF protection rejects private IPs."}, {"id": "security_readme_feedback_retrain", "label": "Feedback-driven Auto-retrain", "file_type": "concept", "source_file": "README.md", "source_location": "line 93", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "Closed-loop improvement: confirmed false positives/negatives from Citizen Portal trigger automatic model retraining, making the model better over time with real deployment data."}, {"id": "security_readme_idn_homoglyph_defense", "label": "IDN/Homoglyph Defense", "file_type": "concept", "source_file": "README.md", "source_location": "line 277", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "Punycode decode + Unicode TR36 confusable fold + Levenshtein distance against whitelist closes the Cyrillic/Greek/Fullwidth lookalike gap that global systems miss."}, {"id": "security_readme_thai_phishing_seed_corpus", "label": "Thai Phishing Seed Corpus (215 URLs)", "file_type": "document", "source_file": "README.md", "source_location": "line 74", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null}, {"id": "security_readme_thai_gov_domain_whitelist", "label": "Thai Gov/Edu/Bank Domain Whitelist (500+)", "file_type": "document", "source_file": "README.md", "source_location": "line 203", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null}, {"id": "security_readme_react_dashboard", "label": "React 18 Dashboard", "file_type": "concept", "source_file": "README.md", "source_location": "line 480-486", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null}, {"id": "security_readme_postgresql_database", "label": "PostgreSQL Database", "file_type": "concept", "source_file": "README.md", "source_location": "line 29", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null}, {"id": "security_readme_ml_pipeline", "label": "ML Pipeline", "file_type": "concept", "source_file": "README.md", "source_location": "line 165-172", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null}, {"id": "security_readme_ci_recall_gate", "label": "CI Recall Gate (Thai recall >= 0.85)", "file_type": "concept", "source_file": "README.md", "source_location": "line 77", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null, "rationale": "CI gate at 0.85 Thai recall threshold prevents any commit from shipping a model that regresses below acceptable Thai-targeting performance."}, {"id": "security_readme_stix_21", "label": "STIX 2.1", "file_type": "concept", "source_file": "README.md", "source_location": "line 101", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "security_readme_domain_reputation_lookup", "label": "Domain Reputation Lookup", "file_type": "concept", "source_file": "README.md", "source_location": "line 440-459", "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null}], "edges": [{"source": "security_readme_phishing_detection_system", "target": "security_readme_phish_features_package", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "line 35-38", "weight": 1.0}, {"source": "security_readme_phishing_detection_system", "target": 