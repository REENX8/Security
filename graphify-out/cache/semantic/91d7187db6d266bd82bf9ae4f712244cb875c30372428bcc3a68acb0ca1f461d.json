{"nodes": [{"id": "nsc2026_02_full_report_full_report", "label": "NSC 2026 Full Report", "file_type": "document", "source_file": "docs/nsc2026/02_full_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null}, {"id": "nsc2026_02_full_report_phishing_detection_system", "label": "Thai Public-Sector Phishing URL Detection System", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": null, "source_url": "https://github.com/reenx8/security", "captured_at": null, "author": "REENX8", "contributor": null}, {"id": "nsc2026_02_full_report_ml_ensemble", "label": "ML Ensemble (RandomForest + XGBoost + Isotonic Calibration)", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a74.2.2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "RF captures non-linear interactions; XGB learns tail/rare URL patterns; soft voting averages probabilities to reduce variance; isotonic calibration converts scores into true probabilities so that threshold 0.7/0.3 has consistent meaning across datasets."}, {"id": "nsc2026_02_full_report_feature_schema_v140", "label": "Feature Schema v1.4.0 (37 Features)", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a74.2.1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deterministic URL-string features avoid train/serve skew; adding num_login_keywords, query_param_count, path_entropy, host_token_count in v1.4.0 captures the 'random host + brand-in-path' pattern dominant in 2024-2025 phishing kits."}, {"id": "nsc2026_02_full_report_rules_engine", "label": "Heuristic Rules Engine", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a74.2.5", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Rules Engine allows operators to override ML decisions without retraining, responds immediately to new phishing kit patterns, and exposes rule_id in every verdict for full auditability and transparency."}, {"id": "nsc2026_02_full_report_idn_homoglyph_defense", "label": "IDN/Homoglyph Defense", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a74.2.3", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Attackers exploit Unicode look-alike characters (Cyrillic, Greek, Fullwidth) to register domains visually identical to legitimate brands; Punycode decode + Unicode TR36 confusable fold + Levenshtein comparison detects homoglyph_distance=0 cases."}, {"id": "nsc2026_02_full_report_path_impersonation_detection", "label": "Path Impersonation Detection (v1.3.0)", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a74.2.4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "OpenPhish 2024-2025 reports the most common phishing pattern as a normal-looking host with brand name embedded in the URL path, so path_brand_hit, has_login_keyword, and has_suspicious_tld features were added."}, {"id": "nsc2026_02_full_report_campaign_clustering", "label": "Campaign Clustering Algorithm", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a74.2.6", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "nsc2026_02_full_report_stix_threat_feed", "label": "Public Threat Feed (STIX 2.1)", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a74.2.7", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No-auth public STIX 2.1 feed enables any agency or researcher to ingest threat indicators into their SIEM without commercial threat-intel costs, following open-source sustainability principles."}, {"id": "nsc2026_02_full_report_brand_watchlist", "label": "Brand Watchlist + Webhook", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "nsc2026_02_full_report_citizen_report_portal", "label": "Citizen Report Portal (No Login)", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Low technical barrier maximizes accessibility for general public and elderly users who cannot install extensions; anonymous reporting reduces friction while still collecting feedback for retraining."}, {"id": "nsc2026_02_full_report_sustainable_innovation", "label": "Sustainable Innovation Framework (4 Pillars)", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a7\u0e02\u0e49\u0e2d\u0e2a\u0e23\u0e38\u0e1b", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "nsc2026_02_full_report_browser_extension_mv3", "label": "Browser Extension Manifest V3", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "nsc2026_02_full_report_fastapi_backend", "label": "FastAPI Backend", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "nsc2026_02_full_report_react_dashboard", "label": "React Dashboard (11 Pages)", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "nsc2026_02_full_report_thai_holdout_100pct_recall", "label": "Thai-targeting Holdout 100% Recall (66/66)", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a7\u0e1c\u0e25\u0e01\u0e32\u0e23\u0e17\u0e14\u0e2a\u0e2d\u0e1a", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "nsc2026_02_full_report_ci_gate", "label": "CI Gate Thai Recall >= 0.85", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Automated CI threshold prevents model regression on Thai-targeting URLs across all commits; ensures deployment quality without manual review."}, {"id": "nsc2026_02_full_report_whitelist_thai_domains", "label": "Thai Brand Whitelist (500+ Domains)", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a7\u0e1a\u0e17\u0e19\u0e33", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Global phishing systems lack Thai-specific whitelist, causing high false negative rate on Thai brand impersonation; 500+ Thai domain whitelist directly addresses this coverage gap."}, {"id": "nsc2026_02_full_report_etda_data_source", "label": "ETDA (Electronic Transactions Development Agency) Data", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a7\u0e1a\u0e17\u0e19\u0e33", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "nsc2026_02_full_report_openphish_citation", "label": "OpenPhish 2024-2025 Dataset", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a74.2.4", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "nsc2026_02_full_report_unicode_tr36", "label": "Unicode TR36 Confusables Standard", "file_type": "concept", "source_file": "docs/nsc2026/02_full_report.md", "source_location": "\u00a74.2.3", "source_u