{"nodes": [{"id": "nsc2026_03_summary_form_summary_form", "label": "NSC 2026 Project Summary Form", "file_type": "document", "source_file": "docs/nsc2026/03_summary_form.md", "source_location": null, "source_url": null, "captured_at": null, "author": "REENX8", "contributor": null}, {"id": "nsc2026_03_summary_form_url_unshortener", "label": "URL Unshortener (18 Providers)", "file_type": "concept", "source_file": "docs/nsc2026/03_summary_form.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Short-link evasion is a gap in most phishing detection systems; async HEAD expansion before scoring closes this without adding latency for normal URLs."}, {"id": "nsc2026_03_summary_form_line_bot", "label": "LINE Messaging API Bot", "file_type": "concept", "source_file": "docs/nsc2026/03_summary_form.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Thai elderly users predominantly use LINE; providing URL checking directly in LINE chat requires no browser install and delivers Thai-language verdicts in a familiar interface."}, {"id": "nsc2026_03_summary_form_content_based_fallback", "label": "Content-based Fallback (Gray-zone HTML Check)", "file_type": "concept", "source_file": "docs/nsc2026/03_summary_form.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "URLs scoring 0.3-0.7 are ambiguous from URL string alone; fetching HTML to check for password fields and brand-in-title disambiguates gray-zone cases with SSRF protection via private IP rejection."}, {"id": "nsc2026_03_summary_form_feedback_auto_retrain", "label": "Feedback Auto-retrain Pipeline", "file_type": "concept", "source_file": "docs/nsc2026/03_summary_form.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Confirmed user feedback is the mo