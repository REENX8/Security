    },
    {
      "id": "nsc2026_02_full_report_ml_ensemble",
      "label": "ML Ensemble (RandomForest + XGBoost + Isotonic Calibration)",
      "file_type": "concept",
      "source_file": "docs/nsc2026/02_full_report.md",
      "source_location": "§4.2.2",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "RF captures non-linear interactions; XGB learns tail/rare URL patterns; soft voting averages probabilities to reduce variance; isotonic calibration converts scores into true probabilities so that threshold 0.7/0.3 has consistent meaning across datasets."
    },
    {
      "id": "nsc2026_02_full_report_feature_schema_v140",
      "label": "Feature Schema v1.4.0 (37 Features)",
      "file_type": "concept",
      "source_file": "docs/nsc2026/02_full_report.md",
      "source_location": "§4.2.1",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Deterministic URL-string features avoid train/serve skew; adding num_login_keywords, query_param_count, path_entropy, host_token_count in v1.4.0 captures the 'random host + brand-in-path' pattern dominant in 2024-2025 phishing kits."
    },
    {
      "id": "nsc2026_02_full_report_rules_engine",
      "label": "Heuristic Rules Engine",
      "file_type": "concept",
      "source_file": "docs/nsc2026/02_full_report.md",
      "source_location": "§4.2.5",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Rules Engine allows operators to override ML decisions without retraining, responds immediately to new phishing kit patterns, and exposes rule_id in every verdict for full auditability and transparency."
    },
    {
      "id": "nsc2026_02_full_report_idn_homoglyph_defense",
      "label": "IDN/Homoglyph Defense",
      "file_type": "concept",
      "source_file": "docs/nsc2026/02_full_report.md",
      "source_location": "§4.2.3",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Attackers exploit Unicode look-alike characters (Cyrillic, Greek, Fullwidth) to register domains visually identical to legitimate brands; Punycode decode + Unicode TR36 confusable fold + Levenshtein comparison detects homoglyph_distance=0 cases."
    },
    {
      "id": "nsc2026_02_full_report_path_impersonation_detection",
      "label": "Path Impersonation Detection (v1.3.0)",
      "file_type": "concept",
      "source_file": "docs/nsc2026/02_full_report.md",
      "source_location": "§4.2.4",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "OpenPhish 2024-2025 reports the most common phishing pattern as a normal-looking host with brand name embedded in the URL path, so path_brand_hit, has_login_keyword, and has_suspicious_tld features were added."
    },
    {
