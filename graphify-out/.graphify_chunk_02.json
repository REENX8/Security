      "id": "nsc2026_02_full_report_phishing_detection_system",
      "label": "Thai Public-Sector Phishing URL Detection System",
      "file_type": "concept",
      "source_file": "docs/nsc2026/02_full_report.md",
      "source_location": null,
      "source_url": "https://github.com/reenx8/security",
