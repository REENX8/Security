      "file_type": "concept",
      "source_file": "docs/nsc2026/02_full_report.md",
      "source_location": "§4.2.7",
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "No-auth public STIX 2.1 feed enables any agency or researcher to ingest threat indicators into their SIEM without commercial threat-intel costs, following open-source sustainability principles."
    },
